#!/usr/bin/env bash
#shellcheck source-path=..
source "$HOME/.bash_functions/strict.bash"
name=$1
group=${2:-}

mise-uninstall() {
	local name latest version
	name=$1
	latest=$2
	version=$3
	if [ "$version" != "$latest" ]; then
		echo "Uninstalling $name $version"
		mise uninstall "${name}@${version}"
	fi
}

# Use JSON output for reliable parsing of versions
# This avoids issues with different text output formats (e.g. including tool names)
if test -n "$group"; then
	versions=$(mise ls --installed --json "$name" | jq -r '.[].version' | grep "^$group" || true)
else
	versions=$(mise ls --installed --json "$name" | jq -r '.[].version' || true)
fi

if [[ -z "$versions" ]]; then
	exit 0
fi

# Determine the latest version among installed versions to avoid uninstalling it
# This is safer than using 'mise latest' which checks online and might not match installed versions
latest=$(echo "$versions" | sort -V | tail -n1)

for version in $versions; do
	mise-uninstall "$name" "$latest" "$version"
done
