#!/usr/bin/env bash

# Colors
if [[ -t 1 ]]; then
  YELLOW=$(tput setaf 3)$(tput bold)
  NC=$(tput sgr0)
  color_opt='-c color.status=always'
else
  YELLOW=''
  NC=''
  color_opt=''
fi

# 1. Get toplevel (fast)
if ! toplevel=$(git rev-parse --show-toplevel 2>/dev/null); then
  # Not in a git repo
  # shellcheck disable=SC2086
  git $color_opt status .
  exit $?
fi

real_pwd=$(pwd -P)

# 2. Collect submodules (recursive)
# Optimized for performance and small number of submodules
collect_submodules() {
  local dir="$1"
  local prefix="$2"
  local gm="$dir/.gitmodules"
  [[ -f "$gm" ]] || return
  while IFS= read -r line; do
    if [[ $line =~ ^[[:space:]]*path[[:space:]]*=[[:space:]]*(.*)$ ]]; then
      local val="${BASH_REMATCH[1]}"
      val="${val%$'\r'}"
      val="${val%% }" # Trim trailing spaces
      local full_path="$val"
      [[ -n "$prefix" ]] && full_path="$prefix/$val"
      echo "$full_path"
      collect_submodules "$toplevel/$full_path" "$full_path"
    fi
  done <"$gm"
}

sm_paths=()
if [[ -f "$toplevel/.gitmodules" ]]; then
  while IFS= read -r sm_rel; do
    [[ -z "$sm_rel" ]] && continue
    abs_sm="$toplevel/$sm_rel"
    # Only submodules under current directory
    if [[ "$abs_sm" == "$real_pwd"/* && "$abs_sm" != "$real_pwd" ]]; then
      # Skip uninitialized submodules: without a .git entry, `git -C` walks
      # upward and reports the parent worktree's status under this header.
      [[ -e "$abs_sm/.git" ]] || continue
      sm_paths+=("$abs_sm")
    fi
  done < <(collect_submodules "$toplevel" "")
fi

# 3. Parallel status using process substitution (in-memory pipes)
# This satisfies the "in memory" and "parallel" requirements.
declare -a fds
declare -a headers
declare -a pids

# Top level
headers+=("${real_pwd/#$HOME/\~}")
# shellcheck disable=SC2086
exec {fd}< <(git $color_opt status . 2>&1)
fds+=("$fd")
pids+=($!)

# Submodules
for sm in "${sm_paths[@]}"; do
  headers+=("${sm/#$HOME/\~}")
  # shellcheck disable=SC2086
  exec {fd}< <(git -C "$sm" $color_opt status . 2>&1)
  fds+=("$fd")
  pids+=($!)
done

# 4. Print results in order
exit_status=0
for i in "${!fds[@]}"; do
  printf "${YELLOW}In %s${NC}\n" "${headers[$i]}"
  cat <&"${fds[$i]}"
  # Close the file descriptor
  current_fd="${fds[$i]}"
  exec {current_fd}<&-
  # Check exit status of the background process
  wait "${pids[$i]}" || exit_status=1
done

exit "$exit_status"
