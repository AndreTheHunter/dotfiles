#!/usr/bin/env bash
source "$HOME/.bash_functions/strict.bash"
#shellcheck disable=2046
brew-try-uninstall homebrew/core/java java java11 $(brew list | ag 'openjdk@?')
for version in \
	graalvm-community \
	corretto \
	corretto-17 \
	corretto-24; do
	mise install java@$version
done
for version in \
	graalvm-community \
	corretto-17 \
	corretto-24 \
	corretto-25; do
	mise-uninstall-old java $version
done
mise use --global java@corretto
