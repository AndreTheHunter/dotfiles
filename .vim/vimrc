source ~/.vim/install-vim-plug.vim
call plug#begin('~/.vim/plugged')
source ~/.vim/plugins.vim
call plug#end()

autocmd BufNewFile,BufRead *.log set filetype=log

"filetype off
source ~/.vim/ale.vim
source ~/.vim/airline.vim
source ~/.vim/vim-lsp.vim
source ~/.vim/common.vim

set backupdir=/tmp//
set directory=/tmp//
set undodir=/tmp//

" GhosTTY cursor shape
" Cursor https://vim.fandom.com/wiki/Change_cursor_shape_in_different_modes#For_iTerm2_on_OS_X
let &t_SI = "\<Esc>[6 q"
let &t_SR = "\<Esc>[4 q"
let &t_EI = "\<Esc>[2 q"
