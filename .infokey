#info
j       next-line
k       prev-line
f       scroll-forward
b       scroll-backward
g       beginning-of-node
G       end-of-node
h       global-prev-node
l       global-next-node
/       search
n       search-next
N       search-previous

#var
link-style=blue
active-link-style=blue,bold,underline
match-style=yellow,bgblue
