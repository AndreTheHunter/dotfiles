#!/usr/bin/env bash
source "$HOME/.bash_functions/strict.bash"
# shellcheck disable=2046
brew-try-uninstall node $(brew list --formula | ag 'node@?')
# mise
# Node.js 14
mise use python@3.10
mise install nodejs@14
# Node.js 16
mise install nodejs@16
# Node.js 20
mise install nodejs@20
# Node.js 23
mise install nodejs@23
# Cleanup old
for version in 14 16 20 23 25; do
	mise-uninstall-old nodejs "$version"
done
# latest
mise install nodejs@latest
mise use --global nodejs@latest
~/install-npm-packages
